<view class="page-shell">
  <view class="hero-card card-animate">
    <view class="hero-top">
      <view>
        <text class="hero-eyebrow">人脸抓拍</text>
        <text class="hero-title">最近人脸图片</text>
        <text class="hero-desc">默认读取最近 20 张人脸抓拍图，支持点击大图预览，并对单张图片加载失败做降级处理。</text>
      </view>
      <button class="action-button compact-button" bindtap="handleManualRefresh" loading="{{loading}}">刷新图片</button>
    </view>

    <view class="page-nav">
      <view class="nav-item" bindtap="goHome">首页</view>
      <view class="nav-item" bindtap="goDetections">检测记录</view>
      <view class="nav-item active">人脸抓拍</view>
    </view>
  </view>

  <view class="glass-panel card-animate">
    <view class="panel-head">
      <view>
        <text class="panel-title">抓拍图库</text>
        <text class="panel-subtitle">单张图片失败不会影响整个页面</text>
      </view>
      <view class="count-badge">20 张内</view>
    </view>

    <view class="meta-grid">
      <view class="meta-card">
        <text class="meta-label">最近刷新</text>
        <text class="meta-value">{{lastRefreshText}}</text>
      </view>
      <view class="meta-card">
        <text class="meta-label">图片来源</text>
        <text class="meta-value">/api/face_image/&lt;id&gt;</text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasError}}" class="error-banner card-animate">
    {{errorMessage}}
  </view>

  <view wx:if="{{images.length}}" class="faces-grid">
    <view wx:for="{{images}}" wx:key="id" class="face-card card-animate">
      <block wx:if="{{!item.imageError}}">
        <image
          class="face-image"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          data-id="{{item.id}}"
          data-url="{{item.imageUrl}}"
          bindtap="previewImage"
          binderror="handleImageError"
        />
      </block>
      <view wx:else class="face-fallback">
        <text>图片加载失败</text>
      </view>
      <view class="face-body">
        <text class="face-score">置信度 {{item.scoreText}}</text>
        <text class="face-meta">{{item.datetime}}</text>
        <text class="face-meta">{{item.device}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty-panel card-animate">
    <text class="empty-title">还没有抓拍内容</text>
    <text class="empty-desc">当后端收到 MQTT 人脸裁剪数据并写入数据库后，这里会显示最新的人脸图片。</text>
  </view>
</view>
