.compact-button {
  min-width: 184rpx;
}

.faces-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
}

.face-card {
  width: 48.6%;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
}

.face-image,
.face-fallback {
  width: 100%;
  height: 280rpx;
  display: block;
}

.face-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(229, 239, 255, 0.58);
  background: linear-gradient(135deg, rgba(17, 29, 49, 0.8), rgba(9, 19, 38, 0.9));
}

.face-body {
  padding: 18rpx;
}

.face-score {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
}

.face-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(229, 239, 255, 0.62);
  font-size: 22rpx;
}
