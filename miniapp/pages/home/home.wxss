.latest-grid {
  margin-top: 18rpx;
}

.compact-empty {
  margin-top: 18rpx;
}

.preview-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
}

.preview-card {
  width: 48.6%;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: rgba(4, 12, 24, 0.5);
  border: 1rpx solid rgba(204, 219, 255, 0.08);
}

.preview-image,
.image-fallback {
  width: 100%;
  height: 220rpx;
  display: block;
}

.image-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(229, 239, 255, 0.58);
  background: linear-gradient(135deg, rgba(17, 29, 49, 0.8), rgba(9, 19, 38, 0.9));
}

.preview-info {
  padding: 18rpx;
}

.preview-score {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
}

.preview-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(229, 239, 255, 0.62);
  font-size: 22rpx;
}
